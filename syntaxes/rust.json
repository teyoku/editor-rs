                "]"
            ],
            "style": {
                "color": "DarkMagenta",
                "attributes": []
            }
        },
        {
            "kind": "Plain",
            "definitions": [
                "(",
                ")"
            ],
            "style": {
                "color": "DarkYellow",
                "attributes": []
            }
        },
        {
            "kind": "Keyword",
            "definitions": [
                "self"
            ],
            "style": {
                "color": "Magenta",
                "attributes": []
            }
        },
        {
            "kind": "Number",
            "definitions": [],
            "style": {
                "color": "Cyan",
                "attributes": []
            }
        }
    ]
}