{
    "language": "Rust",
    "extensions": [
        "rs"
    ],
    "rules": [
        {
            "kind": "Function",
            "definitions": [
                "fn"
            ],
            "style": {
                "color": "Red",
                "attributes": [
                    "Bold"
                ]
            }
        },
        {
            "kind": "Keyword",
            "definitions": [
                "let",
                "mut",
                "const",
                "static",
                "if",
                "else",
                "while",
                "for",
                "loop",
                "match",
                "return",
                "struct",
                "enum",
                "impl",
                "trait",
                "type",
                "pub",
                "use",
                "mod",
                "crate",
                "super",
                "self",
                "Self",
                "true",
                "false",
                "as",
                "in",
                "ref",
                "move",
                "break",
                "continue",
                "where",
                "async",
                "await",
                "dyn"
            ],
            "style": {
                "color": "Blue",
                "attributes": []
            }
        },
        {
            "kind": "Comment",
            "definitions": [
                "//"
            ],
            "style": {
                "color": "DarkGrey",
                "attributes": [
                    "Dim"
                ]
            }
        },
        {
